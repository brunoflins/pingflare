{
  "name": "pingflare",
  "version": "1.4.1",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend,cron -c blue,green,yellow \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:cron\"",
    "dev:backend": "wrangler dev --test-scheduled",
    "dev:frontend": "npm run dev -w frontend",
    "dev:cron": "node scripts/cron-sim.mjs",
    "dev:node": "tsx watch src/server.ts",
    "build": "npm run build -w frontend",
    "build:server": "tsup",
    "start": "node dist-server/server.js",
    "deploy": "npm run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:generate:pg": "drizzle-kit generate --config=drizzle.pg.config.ts",
    "db:generate:mysql": "drizzle-kit generate --config=drizzle.mysql.config.ts",
    "db:migrate:local": "wrangler d1 migrations apply pingflare --local",
    "db:migrate:remote": "wrangler d1 migrations apply pingflare",
    "cf-typegen": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@libsql/client": "^0.17.4",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.66.0",
    "better-sqlite3": "^12.11.1",
    "bits-ui": "2.18.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "jose": "^6.2.3",
    "mysql2": "^3.22.5",
    "node-cron": "^4.4.1",
    "npm-check-updates": "^22.2.7",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260620.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "@types/node-cron": "^3.0.11",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "vite": "^6.4.3 || ^8.0.16"
  }
}
